<?xml version="1.0" encoding="utf-8" ?>
<component name="PlayerScreen" extends="Group">
  <interface>
    <field id="playback" type="assocarray" />
    <field id="exitRequested" type="boolean" alwaysNotify="true" />
    <field id="playbackError" type="string" alwaysNotify="true" />
    <field id="nextPlaybackRequested" type="assocarray" alwaysNotify="true" />
    <field id="nextPlayback" type="assocarray" alwaysNotify="true" />
  </interface>
  <children>
    <Video id="videoNode" width="1280" height="720" enableUI="false" />

    <Group id="streamLoaderGroup" translation="[0,0]" visible="false">
      <Rectangle width="1280" height="720" color="#000000" opacity="0.34" />
      <Rectangle translation="[440,286]" width="400" height="148" color="#111827" opacity="0.94" />
      <Label id="streamLoaderTitleLabel" translation="[480,314]" width="320" horizAlign="center" text="Loading stream" color="#F5F5F5" />
      <Label id="streamLoaderPercentLabel" translation="[480,358]" width="320" horizAlign="center" text="Please wait..." color="#D1D5DB" />
      <Rectangle id="streamLoaderTrack" translation="[500,396]" width="280" height="6" color="#374151" />
      <Rectangle id="streamLoaderFill" translation="[500,396]" width="0" height="6" color="#EF4444" />
    </Group>

    <Group id="resumePromptGroup" translation="[390,214]" visible="false">
      <Rectangle width="500" height="292" color="#111827" opacity="0.96" />
      <Label id="resumePromptTitleLabel" translation="[30,28]" width="440" text="Continue watching?" color="#F5F5F5" />
      <Label id="resumePromptMessageLabel" translation="[30,74]" width="440" color="#D1D5DB" />
      <Group id="resumePromptOptionsHost" translation="[30,126]" />
      <Label id="resumePromptCountdownLabel" translation="[30,246]" width="440" horizAlign="center" color="#9CA3AF" />
    </Group>

    <Group id="bottomRailGroup" translation="[0,400]" visible="false">
      <Rectangle id="bottomRailBackground" width="1280" height="320" color="#101010" opacity="0.84" />
      <Label id="titleLabel" translation="[72,24]" width="860" color="#F5F5F5" />
      <Label id="timeLabel" translation="[1030,28]" width="180" horizAlign="right" color="#D1D5DB" />
      <Group id="seasonCarouselGroup" translation="[72,54]" visible="false">
        <Label id="seasonCarouselTitleLabel" text="Season" width="180" color="#D1D5DB" />
        <Label id="seasonCarouselLeftChevron" text="&lt;" translation="[-42,52]" width="30" horizAlign="center" color="#D1D5DB" visible="false" />
        <Group id="seasonCarouselHost" translation="[0,28]" />
        <Label id="seasonCarouselRightChevron" text="&gt;" translation="[1138,52]" width="30" horizAlign="center" color="#D1D5DB" visible="false" />
      </Group>
      <Rectangle id="progressFocus" translation="[68,196]" width="1144" height="22" color="#F5F5F5" opacity="0.18" visible="false" />
      <Rectangle id="progressTrack" translation="[72,204]" width="1136" height="6" color="#4B5563" />
      <Rectangle id="progressFill" translation="[72,204]" width="0" height="6" color="#EF4444" />
      <Group id="controlsHost" translation="[72,234]" />
      <Group id="focusCursor" translation="[72,234]" visible="false">
        <Rectangle width="232" height="48" color="#E5E7EB" opacity="0.22" />
        <Rectangle width="232" height="4" color="#F5F5F5" />
        <Rectangle translation="[0,44]" width="232" height="4" color="#F5F5F5" />
        <Rectangle width="4" height="48" color="#F5F5F5" />
        <Rectangle translation="[228,0]" width="4" height="48" color="#F5F5F5" />
      </Group>
      <Group id="menuPopover" translation="[720,-238]" visible="false">
        <Rectangle id="menuBackground" width="420" height="264" color="#111827" opacity="0.96" />
        <Label id="menuTitleLabel" translation="[18,14]" width="384" color="#D1D5DB" />
        <Group id="menuItemsHost" translation="[18,48]" />
      </Group>
      <Label id="seasonCarouselStatusLabel" translation="[72,286]" width="700" color="#9CA3AF" visible="false" />
      <Label id="statusLabel" translation="[72,286]" width="700" color="#9CA3AF" />
    </Group>

    <Group id="nextEpisodePromptGroup" translation="[390,214]" visible="false">
      <Rectangle width="500" height="292" color="#111827" opacity="0.96" />
      <Label id="nextEpisodePromptTitleLabel" translation="[30,28]" width="440" text="Play next episode?" color="#F5F5F5" />
      <Label id="nextEpisodePromptMessageLabel" translation="[30,74]" width="440" color="#D1D5DB" />
      <Group id="nextEpisodePromptOptionsHost" translation="[30,126]" />
      <Label id="nextEpisodePromptCountdownLabel" translation="[30,246]" width="440" horizAlign="center" color="#9CA3AF" />
    </Group>

    <Timer id="railHideTimer" repeat="false" duration="4" />
    <Timer id="progressTimer" repeat="true" duration="60" />
    <Timer id="statusClearTimer" repeat="false" duration="2.5" />
    <Timer id="resumePromptTimer" repeat="true" duration="1" />
    <Timer id="nextEpisodeCountdownTimer" repeat="true" duration="1" />
    <Timer id="seekDebounceTimer" repeat="false" duration="0.45" />
    <Timer id="seekSettleTimer" repeat="false" duration="2.5" />
  </children>
  <script type="text/brightscript" uri="pkg:/source/services/PlayerPreferenceStore.brs" />
  <script type="text/brightscript" uri="pkg:/components/screens/PlayerScreen.brs" />
</component>
